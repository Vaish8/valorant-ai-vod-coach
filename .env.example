# Application
APP_NAME=valorant-ai-vod-coach
APP_ENV=development
APP_DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3000

# Database
POSTGRES_DB=valorant_vod_coach
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# AI / LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Storage
UPLOAD_DIR=sample_data/uploads
MAX_UPLOAD_SIZE_MB=500

# Security
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256